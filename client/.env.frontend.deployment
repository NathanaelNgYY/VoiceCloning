# Optional when the frontend is hosted separately from the Node API.
# Leave unset when the Express server serves the built client from the same origin.

# Use the backend origin only, without a trailing /api.
# In Lambda mode, this is the API Gateway endpoint.
# VITE_API_BASE_URL=https://api.example.com

# In Lambda mode, browser SSE connects directly to the GPU worker ALB.
# Use the public HTTPS ALB origin, without a trailing slash.
# VITE_GPU_WORKER_URL=https://gpu-worker.example.com

# Optional. Set only when the live WebSocket gateway has a different origin from
# VITE_GPU_WORKER_URL. The Live tab derives wss:// from this URL.
# VITE_LIVE_GATEWAY_URL=https://live-gateway.example.com

# VITE_APP_BASENAME=/
