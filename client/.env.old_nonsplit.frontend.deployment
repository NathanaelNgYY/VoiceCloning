# For the split CloudFront deployment, leave these unset so each app uses
# same-origin /api, /train/progress, and /api/live/chat/realtime paths.
# Set them only if the browser must call a different public origin.
# VITE_API_BASE_URL=https://d3dghqhnk7aoku.cloudfront.net

# VITE_GPU_WORKER_URL=https://d3dghqhnk7aoku.cloudfront.net

# VITE_LIVE_GATEWAY_URL=https://live-gateway.example.com

# VITE_APP_BASENAME=/

# Build-mode split:
# VITE_APP_MODE=training
# VITE_APP_MODE=live-fast
