NODE_ENV=production
PORT=3002
CORS_ORIGIN=https://your-frontend-cloudfront-domain.example.com

# Required for the Live chatbot WebSocket bridge. Keep this on the server side.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VAD=semantic_vad
OPENAI_REALTIME_SYSTEM_PROMPT=You are a casual, helpful assistant. Keep replies concise and conversational. Always respond only in English.
