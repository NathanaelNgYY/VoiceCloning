PORT=3000
S3_BUCKET=interns2026-small-projects-bucket-shared
S3_REGION=ap-southeast-1
S3_PREFIX=echolect/
GPU_WORKER_URL=http://localhost:3001
GPU_WORKER_PUBLIC_URL=http://localhost:3001
GPU_INSTANCE_ID=
GPU_INSTANCE_REGION=ap-northeast-2
# Minutes of no worker activity before the scheduled idle checker stops EC2.
# Keep 0 locally unless you are testing the idle-check endpoint.
GPU_IDLE_STOP_MINUTES=0
# Optional local UI test mode. Set stopped to show the GPU start button without using EC2.
# GPU_INSTANCE_MOCK_STATE=stopped
# GPU_INSTANCE_MOCK_READY_DELAY_MS=1500
CORS_ORIGIN=http://localhost:5173
MODEL_SOURCE=s3
ARTIFACT_SOURCE=gpu-worker

# Only needed when local flows still use S3 uploads/results.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_DEFAULT_REGION=ap-southeast-1
# AWS_SESSION_TOKEN=
