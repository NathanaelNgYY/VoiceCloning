# Copy this file to server/.env for local development.
# In AWS/ECS/App Runner you can inject the same values as environment variables instead.

# Required when INFERENCE_MODE=local: path to a Linux- or Windows-ready GPT-SoVITS installation that includes its runtime/python environment.
GPT_SOVITS_ROOT=/opt/gpt-sovits

# Optional server settings
NODE_ENV=production
PORT=3000
SERVER_HOST=0.0.0.0
INFERENCE_MODE=local
# Local inference mode only. In split-host deployments, the GPU worker owns api_v2.py instead.
INFERENCE_HOST=127.0.0.1
INFERENCE_PORT=9880
TRUST_PROXY=true
SERVE_CLIENT_DIST=true

# Optional: restrict browser access to specific origins when the frontend is hosted separately.
# Example: https://voice.example.com,https://admin.example.com
# CORS_ORIGINS=

# Optional: move writable data outside GPT_SOVITS_ROOT for EFS/EBS mounts.
# VOICE_CLONING_DATA_ROOT=/mnt/voice-data/data
# VOICE_CLONING_LOG_ROOT=/mnt/voice-data/logs
# VOICE_CLONING_TEMP_ROOT=/mnt/voice-data/temp
# SOVITS_WEIGHTS_DIR=/mnt/voice-data/weights/sovits
# GPT_WEIGHTS_DIR=/mnt/voice-data/weights/gpt

# ── Storage mode ──
# STORAGE_MODE=s3

# ── S3 configuration (required when STORAGE_MODE=s3) ──
# S3_BUCKET=my-voice-cloning-bucket
# S3_REGION=ap-southeast-1
# S3_PREFIX=prod/

# ── GPU Worker (required when STORAGE_MODE=s3; set explicitly for split-host deployments) ──
# GPU_WORKER_HOST=10.0.2.25
# GPU_WORKER_PORT=3001
