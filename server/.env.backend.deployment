NODE_ENV=production
PORT=3000
SERVER_HOST=0.0.0.0

INFERENCE_MODE=remote
STORAGE_MODE=s3

TRUST_PROXY=true
SERVE_CLIENT_DIST=false
# If the frontend is on a different domain, set its exact origin here.
# Same-origin deployments are allowed automatically.
# CORS_ORIGINS=https://your-frontend.example.com

S3_BUCKET=interns2026-small-projects-bucket-shared
S3_REGION=ap-southeast-1
S3_PREFIX=echolect/

GPU_WORKER_HOST=<GPU_PRIVATE_IP>
GPU_WORKER_PORT=3001

# Required for the Live chatbot tab. Keep this on the backend only.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VAD=semantic_vad
OPENAI_REALTIME_SYSTEM_PROMPT=You are a casual, helpful assistant. Keep replies concise and conversational. Always respond only in English.
